{
  "name": "aep",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "core/*",
    "packages/*",
    "services/*",
    "examples/*"
  ],
  "scripts": {
    "bootstrap": "bash scripts/dev/bootstrap.sh",
    "build": "npm run typecheck && npm run build:ui",
    "typecheck": "tsc -p core/control-plane/tsconfig.json --noEmit",
    "test": "npm run typecheck && npm run build:ui",
    "dev:control-plane": "wrangler dev --config core/control-plane/wrangler.toml",
    "dev:sample-worker": "wrangler dev --config examples/sample-worker/wrangler.toml",
    "dev:deploy": "tsx scripts/dev/test-deploy.ts",
    "dev:dashboard": "npm --workspace @aep/dashboard run dev",
    "dev:ops-console": "npm --workspace @aep/ops-console run dev",
    "dev:agent": "npm --workspace @aep/operator-agent run dev",
    "build:dashboard": "npm --workspace @aep/dashboard run build",
    "build:ops-console": "npm --workspace @aep/ops-console run build",
    "build:ui": "npm run build:dashboard && npm run build:ops-console",
    "deploy:node": "tsx scripts/deploy/run-node-deploy.ts",
    "teardown:node": "tsx scripts/deploy/run-node-teardown.ts",
    "wait:url": "tsx scripts/ci/wait-for-url.ts",
    "check:health": "tsx scripts/ci/check-health.ts",
    "smoke:test": "tsx scripts/ci/smoke-test.ts",
    "ci:agent-timeout-recovery-check": "tsx scripts/ci/agent-timeout-recovery-check.ts",
    "ci:scheduled-routing-check": "tsx scripts/ci/scheduled-routing-check.ts",
    "ci:manager-advisory-check": "tsx scripts/ci/manager-advisory-check.ts",
    "ci:operator-surface-check": "tsx scripts/ci/operator-surface-check.ts",
    "ci:manager-policy-overlay-check": "tsx scripts/ci/manager-policy-overlay-check.ts",
    "ci:multi-worker-department-check": "tsx scripts/ci/multi-worker-department-check.ts",
    "ci:paperclip-company-handoff-check": "tsx scripts/ci/paperclip-company-handoff-check.ts",
    "ci:escalation-audit-check": "tsx scripts/ci/escalation-audit-check.ts",
    "ci:escalation-lifecycle-check": "tsx scripts/ci/escalation-lifecycle-check.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.8.0"
  },
  "dependencies": {
    "undici": "^7.24.5"
  }
}
