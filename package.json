{
  "name": "aep",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "core/*",
    "packages/*",
    "services/*",
    "examples/*"
  ],
  "scripts": {
    "bootstrap": "bash scripts/dev/bootstrap.sh",
    "build": "npm run typecheck && npm run build:ui",
    "typecheck": "tsc -p core/control-plane/tsconfig.json --noEmit",
    "test": "npm run typecheck && npm run build:ui",
    "dev:control-plane": "wrangler dev --config core/control-plane/wrangler.jsonc",
    "dev:sample-worker": "wrangler dev --config examples/sample-worker/wrangler.toml",
    "dev:deploy": "tsx scripts/dev/test-deploy.ts",
    "dev:stack": "tsx scripts/dev/dev-stack.ts",
    "dev:stack:stop": "tsx scripts/dev/dev-stack-stop.ts",
    "dev:write-service-map": "tsx scripts/dev/write-service-map.ts",
    "dev:dashboard": "npm --workspace @aep/dashboard run dev",
    "dev:ops-console": "npm --workspace @aep/ops-console run dev",
    "dev:agent": "npm --workspace @aep/operator-agent run dev",
    "build:dashboard": "npm --workspace @aep/dashboard run build",
    "build:ops-console": "npm --workspace @aep/ops-console run build",
    "build:ui": "npm run build:dashboard && npm run build:ops-console",
    "deploy:node": "tsx scripts/deploy/run-node-deploy.ts",
    "teardown:node": "tsx scripts/deploy/run-node-teardown.ts",

    "wait:url": "tsx scripts/ci/checks/environment/wait-for-url.ts",
    "check:health": "tsx scripts/ci/checks/environment/check-health.ts",
    "smoke:test": "tsx scripts/ci/checks/environment/smoke-test.ts",

    "ci:agent-timeout-recovery-check": "tsx scripts/ci/checks/scenarios/agent-timeout-recovery-check.ts",
    "ci:approval-state-machine-check": "tsx scripts/ci/checks/policy/approval-state-machine-check.ts",
    "ci:scheduled-routing-check": "tsx scripts/ci/checks/policy/scheduled-routing-check.ts",
    "ci:manager-advisory-check": "tsx scripts/ci/checks/policy/manager-advisory-check.ts",
    "ci:operator-surface-check": "tsx scripts/ci/checks/contracts/operator-surface-check.ts",
    "ci:operator-agent-contract-check": "tsx scripts/ci/checks/contracts/operator-agent-contract-check.ts",
    "ci:task-dependency-integrity-check": "tsx scripts/ci/checks/contracts/task-dependency-integrity-check.ts",
    "ci:task-artifact-contract-check": "tsx scripts/ci/checks/contracts/task-artifact-contract-check.ts",
    "ci:task-run-cognitive-contract-check": "tsx scripts/ci/checks/contracts/task-run-cognitive-contract-check.ts",
    "ci:employee-cognition-boundary-check": "tsx scripts/ci/checks/contracts/employee-cognition-boundary-check.ts",
    "ci:public-rationale-artifact-check": "tsx scripts/ci/checks/contracts/public-rationale-artifact-check.ts",
    "ci:message-thread-contract-check": "tsx scripts/ci/checks/contracts/message-thread-contract-check.ts",
    "ci:approval-thread-contract-check": "tsx scripts/ci/checks/contracts/approval-thread-contract-check.ts",
    "ci:escalation-thread-contract-check": "tsx scripts/ci/checks/contracts/escalation-thread-contract-check.ts",
    "ci:thread-linkage-invariant-check": "tsx scripts/ci/checks/contracts/thread-linkage-invariant-check.ts",
    "ci:approval-thread-action-contract-check": "tsx scripts/ci/checks/contracts/approval-thread-action-contract-check.ts",
    "ci:approval-thread-conflict-contract-check": "tsx scripts/ci/checks/contracts/approval-thread-conflict-contract-check.ts",
    "ci:escalation-thread-action-contract-check": "tsx scripts/ci/checks/contracts/escalation-thread-action-contract-check.ts",
    "ci:thread-task-delegation-contract-check": "tsx scripts/ci/checks/contracts/thread-task-delegation-contract-check.ts",
    "ci:operator-agent-behavior-check": "tsx scripts/ci/checks/policy/operator-agent-behavior-check.ts",
    "ci:employee-scope-check": "tsx scripts/ci/checks/contracts/employee-scope-check.ts",
    "ci:operator-agent-org-schema-check": "tsx scripts/ci/checks/schema/operator-agent-org-schema-check.ts",
    "ci:org-schema-check": "tsx scripts/ci/checks/schema/org-schema-check.ts",
    "ci:org-inventory-route-check": "tsx scripts/ci/checks/schema/org-inventory-route-check.ts",
    "ci:runtime-tenant-catalog-check": "tsx scripts/ci/checks/contracts/runtime-tenant-catalog-check.ts",
    "ci:runtime-projection-check": "tsx scripts/ci/checks/contracts/runtime-projection-check.ts",
    "ci:runtime-provenance-check": "tsx scripts/ci/checks/contracts/runtime-provenance-check.ts",
    "ci:runtime-read-safety": "tsx scripts/ci/checks/contracts/validate-runtime-read-safety.ts",
    "ci:service-provider-check": "tsx scripts/ci/checks/contracts/service-provider-check.ts",
    "ci:provider-provenance-check": "tsx scripts/ci/checks/contracts/provider-provenance-check.ts",
    "ci:post-deploy-validation": "tsx scripts/ci/checks/scenarios/post-deploy-validation.ts",
    "ci:manager-policy-overlay-check": "tsx scripts/ci/checks/policy/manager-policy-overlay-check.ts",
    "ci:multi-worker-department-check": "tsx scripts/ci/checks/scenarios/multi-worker-department-check.ts",
    "ci:paperclip-company-handoff-check": "tsx scripts/ci/checks/scenarios/paperclip-company-handoff-check.ts",
    "ci:approval-thread-delegation-check": "tsx scripts/ci/checks/scenarios/approval-thread-delegation-check.ts",
    "ci:escalation-thread-delegation-check": "tsx scripts/ci/checks/scenarios/escalation-thread-delegation-check.ts",
    "ci:escalation-audit-check": "tsx scripts/ci/checks/policy/escalation-audit-check.ts",
    "ci:escalation-lifecycle-check": "tsx scripts/ci/checks/policy/escalation-lifecycle-check.ts",
    "ci:paperclip-first-execution-check": "tsx scripts/ci/checks/scenarios/paperclip-first-execution-check.ts",
    "ci:synthetic-failure-test": "tsx scripts/ci/checks/scenarios/synthetic-failure-test.ts",

    "ci:check-health:layered": "tsx scripts/ci/checks/environment/check-health.ts",
    "ci:org-schema-check:layered": "tsx scripts/ci/checks/schema/org-schema-check.ts",
    "ci:runtime-projection-check:layered": "tsx scripts/ci/checks/contracts/runtime-projection-check.ts",
    "ci:employee-scope-check:layered": "tsx scripts/ci/checks/contracts/employee-scope-check.ts",
    "ci:manager-policy-overlay-check:layered": "tsx scripts/ci/checks/policy/manager-policy-overlay-check.ts",
    "ci:post-deploy-validation:layered": "tsx scripts/ci/checks/scenarios/post-deploy-validation.ts",
    "ci:synthetic-failure-test:layered": "tsx scripts/ci/checks/scenarios/synthetic-failure-test.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.8.0"
  },
  "dependencies": {
    "undici": "^7.24.5"
  }
}