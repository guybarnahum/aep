{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@aep/shared/*": ["../packages/shared/src/*"],
      "@aep/deployment-engine/*": ["../services/deployment-engine/src/*"]
    }
  },
  "include": ["deploy/**/*.ts", "dev/**/*.ts"]
}
