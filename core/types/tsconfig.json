{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "node"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@aep/types/*": ["src/*"],
      "@aep/event-schema/*": ["../../packages/event-schema/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../packages/event-schema/src/**/*.ts"
  ]
}
