{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "node"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "../workflow-engine/src/**/*.ts",
    "../types/src/**/*.ts",
    "../../packages/**/*.ts",
    "../../services/**/*.ts"
  ]
}