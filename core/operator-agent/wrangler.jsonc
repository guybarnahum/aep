{
  "name": "aep-operator-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-25",
  "kv_namespaces": [
    {
      "binding": "OPERATOR_AGENT_KV",
      "id": "7fe56cac65c04fc18c12093b0ee0d201"
    }
  ],
  "env": {
    "async_validation": {
      "kv_namespaces": [
        {
          "binding": "OPERATOR_AGENT_KV",
          "id": "bc7e86bde9ba478bb3d99068ea3b67d6"
        }
      ],
      "vars": {
        "AEP_CRON_FALLBACK_ENABLED": "true",
        "ENABLE_TEST_ENDPOINTS": "true",
        "PAPERCLIP_SHARED_SECRET": "",
        "PAPERCLIP_AUTH_REQUIRED": "false"
      },
      "services": [
        {
          "binding": "CONTROL_PLANE",
          "service": "aep-control-plane-async-validation"
        }
      ]
    },
    "staging": {
      "kv_namespaces": [
        {
          "binding": "OPERATOR_AGENT_KV",
          "id": "f5c93e01bce8489fad198ab6d122a4b5"
        }
      ],
      "vars": {
        "AEP_CRON_FALLBACK_ENABLED": "true",
        "PAPERCLIP_SHARED_SECRET": "",
        "PAPERCLIP_AUTH_REQUIRED": "false"
      },
      "services": [
        {
          "binding": "CONTROL_PLANE",
          "service": "aep-control-plane-staging"
        }
      ]
    },
    "production": {
      "kv_namespaces": [
        {
          "binding": "OPERATOR_AGENT_KV",
          "id": "5439b1945f0b4367ab9d59387321d622"
        }
      ],
      "vars": {
        "AEP_CRON_FALLBACK_ENABLED": "true",
        "PAPERCLIP_SHARED_SECRET": "",
        "PAPERCLIP_AUTH_REQUIRED": "false"
      },
      "services": [
        {
          "binding": "CONTROL_PLANE",
          "service": "aep-control-plane-production"
        }
      ]
    }
  },
  "vars": {
    "AEP_CRON_FALLBACK_ENABLED": "true",
    "PAPERCLIP_SHARED_SECRET": "",
    "PAPERCLIP_AUTH_REQUIRED": "false"
  },
  "triggers": {
    "crons": ["* * * * *", "*/5 * * * *"]
  }
}
